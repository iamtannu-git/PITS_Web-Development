@model WebDevelopment.Models.ErrorViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Attractive Dashboard</title>
  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Font Awesome -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
  <!-- Chart.js -->
  
  <style>
    body { background: #f5f7fb; }
    .card { border: none; border-radius: 1rem; }
    .stat-icon { font-size: 1.8rem; }
    .sidebar { min-height: 100vh; background: #111827; }
    .sidebar a { color: #cbd5e1; text-decoration: none; display: block; padding: 12px 16px; }
    .sidebar a:hover { background: #1f2937; color: #fff; }
    .navbar { background: #fff; }
  </style>
</head>
<body>
  <div class="container-fluid">
    <div class="row">
      <!-- Sidebar -->
      <nav class="col-md-2 sidebar p-3">
        <h4 class="text-white mb-4"><i class="fa-solid fa-chart-line"></i> Dashboard</h4>
        <a href="#"><i class="fa-solid fa-house me-2"></i>Home</a>
        <a href="#"><i class="fa-solid fa-user me-2"></i>Users</a>
        <a href="#"><i class="fa-solid fa-chart-pie me-2"></i>Reports</a>
        <a href="#"><i class="fa-solid fa-gear me-2"></i>Settings</a>
      </nav>

      <!-- Main -->
      <main class="col-md-10 ms-sm-auto">
        <nav class="navbar shadow-sm p-3 mb-4">
          <span class="navbar-brand">Welcome Back 👋</span>
          <div>
            <i class="fa-solid fa-bell me-3"></i>
            <i class="fa-solid fa-user-circle"></i>
          </div>
        </nav>

        <div class="container">
          <!-- Stats -->
          <div class="row g-4">
            <div class="col-md-3">
              <div class="card shadow-sm p-3">
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <h6>Total Users</h6>
                    <h3 id="usersCount">0</h3>
                  </div>
                  <i class="fa-solid fa-users stat-icon text-primary"></i>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card shadow-sm p-3">
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <h6>Revenue</h6>
                    <h3 id="revenueCount">$0</h3>
                  </div>
                  <i class="fa-solid fa-dollar-sign stat-icon text-success"></i>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card shadow-sm p-3">
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <h6>Orders</h6>
                    <h3 id="ordersCount">0</h3>
                  </div>
                  <i class="fa-solid fa-cart-shopping stat-icon text-warning"></i>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card shadow-sm p-3">
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <h6>Visitors</h6>
                    <h3 id="visitorsCount">0</h3>
                  </div>
                  <i class="fa-solid fa-eye stat-icon text-danger"></i>
                </div>
              </div>
            </div>
          </div>

          <!-- Charts -->
          <div class="row mt-4 g-4">
            <div class="col-md-8">
              <div class="card shadow-sm p-4">
                <h5>Sales Overview</h5>
                <canvas id="salesChart"></canvas>
              </div>
            </div>
            <div class="col-md-4">
              <div class="card shadow-sm p-4">
                <h5>User Distribution</h5>
                <canvas id="userChart"></canvas>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>

<script>
    // Dynamic counters
    const data = {
      users: 1245,
      revenue: 53240,
      orders: 320,
      visitors: 8900
    };

    function animateValue(id, start, end, duration, prefix = '') {
      let range = end - start;
      let stepTime = Math.abs(Math.floor(duration / range));
      let current = start;
      const obj = document.getElementById(id);
      const timer = setInterval(function () {
        current += 1;
        obj.textContent = prefix + current.toLocaleString();
        if (current == end) clearInterval(timer);
      }, stepTime);
    }

    animateValue('usersCount', 0, data.users, 1000);
    animateValue('revenueCount', 0, data.revenue, 1000, '$');
    animateValue('ordersCount', 0, data.orders, 1000);
    animateValue('visitorsCount', 0, data.visitors, 1000);

    // Charts
    new Chart(document.getElementById('salesChart'), {
      type: 'line',
      data: {
        labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
        datasets: [{
          label: 'Sales',
          data: [120, 190, 300, 250, 220, 400],
          fill: false,
          tension: 0.4
        }]
      }
    });

    new Chart(document.getElementById('userChart'), {
      type: 'doughnut',
      data: {
        labels: ['Desktop', 'Mobile', 'Tablet'],
        datasets: [{
          data: [55, 35, 10]
        }]
      }
    });
  </script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</body>
</html>
